# ══════════════════════════════════════════════════════════════════════════════
# WONDERBOX BACKEND - ENVIRONMENT CONFIGURATION
# ══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your actual values
# Never commit .env to git (it's in .gitignore)

# ──────────────────────────────────────────────────────────────────────────────
# Application Settings
# ──────────────────────────────────────────────────────────────────────────────
PROJECT_NAME="WonderBox Backend"
STORAGE_DIR="./storage"
DEFAULT_EXPIRY_DAYS=25

# ──────────────────────────────────────────────────────────────────────────────
# Security & Authentication
# ──────────────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY="CHANGE-THIS-TO-A-RANDOM-SECRET-KEY-IN-PRODUCTION"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ──────────────────────────────────────────────────────────────────────────────
# Speech-to-Text (STT) Configuration
# ──────────────────────────────────────────────────────────────────────────────

# Primary STT provider: local_whisper | groq | openai
# Recommendation:
#   - Development: local_whisper (free, no API needed)
#   - Production (low volume): groq (free tier, fast)
#   - Production (high volume): local_whisper on GPU server
STT_PRIMARY_PROVIDER="local_whisper"

# Enable fallback to other providers if primary fails
STT_ENABLE_FALLBACK="true"

# ── Local Whisper Settings ────────────────────────────────────────────────────
# Model size: tiny, base, small, medium, large-v2, large-v3
# Trade-off: larger = more accurate but slower and more memory
#   tiny:   ~1GB RAM, fast but less accurate
#   base:   ~1GB RAM, good balance for Hindi/English
#   small:  ~2GB RAM, better accuracy
#   medium: ~5GB RAM, high accuracy
#   large:  ~10GB RAM, best accuracy
WHISPER_MODEL_SIZE="base"

# Device: cpu | cuda (if you have NVIDIA GPU)
WHISPER_DEVICE="cpu"

# Compute type: int8 (fastest, CPU) | float16 (GPU) | float32 (best quality)
WHISPER_COMPUTE_TYPE="int8"

# ── Groq API Settings ─────────────────────────────────────────────────────────
# Get your free API key from: https://console.groq.com/keys
# Free tier: Generous limits, very fast inference
GROQ_API_KEY=""

# Model: whisper-large-v3 (recommended) | distil-whisper-large-v3-en (English only, faster)
GROQ_MODEL="whisper-large-v3"

# ── OpenAI API Settings ───────────────────────────────────────────────────────
# Get your API key from: https://platform.openai.com/api-keys
# Pricing: ~$0.006 per minute of audio
OPENAI_API_KEY=""

# Model: whisper-1 (only option currently)
OPENAI_WHISPER_MODEL="whisper-1"

# ──────────────────────────────────────────────────────────────────────────────
# Image Generation Configuration
# ──────────────────────────────────────────────────────────────────────────────
# IMPORTANT: API keys are held by BACKEND ONLY, never exposed to IoT devices!
# Devices authenticate with device_token, backend enforces quotas and makes API calls.

# Primary image provider: replicate | stability
# Recommendation:
#   - Development: replicate with Flux Schnell (free tier)
#   - Production (budget): replicate with Flux Dev (fast + cheap ~$0.003/image)
#   - Production (quality): stability with SDXL line-art preset (~$0.003/image)
IMAGE_PRIMARY_PROVIDER="replicate"

# Enable fallback to other providers if primary fails
IMAGE_ENABLE_FALLBACK="true"

# Image dimensions (512x512 recommended for stickers, prints well)
IMAGE_WIDTH=512
IMAGE_HEIGHT=512

# ── Replicate Settings ────────────────────────────────────────────────────────
# Get your API token from: https://replicate.com/account/api-tokens
# ONE token for ALL devices (backend holds the key)
# Free tier available for Flux Schnell model
REPLICATE_API_TOKEN=""

# Model options:
#   - black-forest-labs/flux-schnell (FREE tier, fast, good quality)
#   - black-forest-labs/flux-dev (better quality, ~$0.003/image)
#   - stability-ai/sdxl (high quality line art, ~$0.003/image)
REPLICATE_MODEL="black-forest-labs/flux-schnell"

# ── Stability AI Settings ─────────────────────────────────────────────────────
# Get your API key from: https://platform.stability.ai/account/keys
# ONE key for ALL devices (backend holds the key)
# Pricing: ~$0.003-0.01 per image
STABILITY_API_KEY=""

# Model: stable-diffusion-xl-1024-v1-0 | sd3-medium | sd3-large
# SDXL has excellent "line-art" preset perfect for coloring books!
STABILITY_MODEL="stable-diffusion-xl-1024-v1-0"

# ──────────────────────────────────────────────────────────────────────────────
# Usage Limits & Quotas (Cost Protection)
# ──────────────────────────────────────────────────────────────────────────────
# These limits are enforced by the BACKEND to protect your API costs.
# Devices never see or bypass these limits.

# Default stickers per device per day (if device.daily_limit not set in DB)
DEFAULT_DAILY_STICKER_LIMIT=10

# Company-wide limit (total across ALL devices)
# Protects against unexpected API cost spikes
COMPANY_DAILY_LIMIT=1000

# Premium subscription limit (when subscription system is implemented)
# Can override device limit for paid users
SUBSCRIPTION_OVERRIDE_LIMIT=50

# ──────────────────────────────────────────────────────────────────────────────
# Database Configuration (add when needed)
# ──────────────────────────────────────────────────────────────────────────────
# DATABASE_URL="postgresql://user:password@localhost:5432/wonderbox"

# ──────────────────────────────────────────────────────────────────────────────
# Cloud Storage (add when needed)
# ──────────────────────────────────────────────────────────────────────────────
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_REGION="us-east-1"
# S3_BUCKET_NAME="wonderbox-stickers"
